<?xml version="1.0" encoding="utf-8"?>
<!--
    Contact row — light theme, dpad-first, 240px wide.
    Green dot = allowed, gray dot = blocked.
    ALLOWED/BLOCKED label right-aligned.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:background="@drawable/contact_item_selector">

    <!-- Status dot -->
    <View
        android:id="@+id/contact_status_dot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginRight="10dp"
        android:background="@drawable/status_dot" />

    <!-- Name + number -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/contact_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1C1C1E"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/contact_number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#8E8E93"
            android:singleLine="true" />

    </LinearLayout>

    <!-- Status label -->
    <TextView
        android:id="@+id/contact_status_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textStyle="bold"
        android:paddingLeft="6dp"
        android:paddingRight="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp" />

</LinearLayout>