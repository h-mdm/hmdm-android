<?xml version="1.0" encoding="utf-8"?>
<!--
    Main launcher layout — light theme.
    All binding IDs preserved exactly — MainActivity references these by name.

    Structure (top to bottom):
      status_header          — white card, clock + title + battery
      activity_main_content  — app grid RecyclerView
      activity_bottom_layout — bottom dock RecyclerView
      phone_button_bar       — green PHONE button fixed at bottom

    Loading overlay is centered over everything until showContent=true.
-->
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:bind="http://schemas.android.com/apk/res-auto">

    <data>
        <variable name="message"          type="String"/>
        <variable name="downloading"      type="Boolean"/>
        <variable name="showContent"      type="Boolean"/>
        <variable name="fileLength"       type="Long"/>
        <variable name="downloadedLength" type="Long"/>
    </data>

    <RelativeLayout
        android:id="@+id/activity_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F7"
        tools:context="com.hmdm.launcher.ui.MainActivity">

        <!-- ================================================ -->
        <!-- LOADING STATE                                     -->
        <!-- Shown until configuration is loaded and content  -->
        <!-- is ready to display. Centered over the screen.   -->
        <!-- ================================================ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="@dimen/activity_horizontal_margin"
            android:paddingRight="@dimen/activity_horizontal_margin"
            android:paddingTop="@dimen/activity_vertical_margin"
            android:paddingBottom="@dimen/activity_vertical_margin"
            android:orientation="vertical"
            android:layout_centerInParent="true"
            android:gravity="center">

            <ProgressBar
                android:id="@+id/loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/activity_vertical_margin"
                android:indeterminateTint="#007AFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@{message}"
                android:textColor="#8E8E93"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="@dimen/activity_vertical_margin" />

            <!-- Download progress bar -->
            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/activity_vertical_margin"
                style="?android:attr/progressBarStyleHorizontal"
                android:progressTint="#007AFF"
                android:max="100"
                bind:boolToVisible="@{downloading}" />

            <!-- Downloaded / total bytes -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                bind:boolToVisible="@{downloading}">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#8E8E93"
                    android:textSize="12sp"
                    android:text="@{String.valueOf(downloadedLength)}" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#C7C7CC"
                    android:textSize="12sp"
                    android:text=" / " />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#8E8E93"
                    android:textSize="12sp"
                    android:text="@{String.valueOf(fileLength)}" />

            </LinearLayout>

        </LinearLayout>

        <!-- ================================================ -->
        <!-- CONTENT STATE                                     -->
        <!-- Shown once configuration is loaded.              -->
        <!-- ================================================ -->
        <RelativeLayout
            android:id="@+id/activity_main_content_wrapper"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            bind:boolToVisible="@{showContent}">

            <!-- Wallpaper / background image (set by HomeCustomizationActivity) -->
            <ImageView
                android:id="@+id/activity_main_background"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <!-- ============================================ -->
            <!-- PHONE BUTTON BAR — fixed at bottom          -->
            <!-- ============================================ -->


            <!-- ============================================ -->
            <!-- STATUS HEADER — fixed at top                -->
            <!-- ============================================ -->
            <LinearLayout
                android:id="@+id/status_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#FFFFFF"
                android:elevation="4dp"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <!-- Clock — left side -->
                <TextView
                    android:id="@+id/clock"
                    android:layout_width="@dimen/status_bar_side_width"
                    android:layout_height="wrap_content"
                    android:textColor="#1C1C1E"
                    android:textSize="@dimen/title_text_size" />

                <!-- Device/config title — centre -->
                <TextView
                    android:id="@+id/activity_main_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="#1C1C1E"
                    android:textSize="@dimen/title_text_size" />

                <!-- Battery indicator — right side -->
                <com.hmdm.launcher.ui.custom.BatteryStateView
                    android:id="@+id/battery_state"
                    android:layout_width="@dimen/status_bar_side_width"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="5dp" />

            </LinearLayout>

            <!-- ============================================ -->
            <!-- MAIN APP GRID                               -->
            <!-- Fills space between header and bottom dock  -->
            <!-- ============================================ -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/activity_main_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@+id/status_header"
                android:layout_above="@+id/activity_bottom_layout"
                android:background="#00000000"
                android:paddingTop="4dp"
                android:clipToPadding="false" />

            <!-- ============================================ -->
            <!-- BOTTOM DOCK                                 -->
            <!-- Sits immediately above the phone button bar -->
            <!-- ============================================ -->
            <RelativeLayout
                android:id="@+id/activity_bottom_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_above="@+id/phone_button_bar"
                android:background="#FFFFFF"
                android:elevation="2dp">

                <!-- Thin separator above dock -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E5EA"
                    android:layout_alignParentTop="true" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/activity_bottom_line"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp" />

            </RelativeLayout>

        </RelativeLayout>

    </RelativeLayout>

</layout>