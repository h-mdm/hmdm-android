<?xml version="1.0" encoding="utf-8"?>
<!--
    Incoming call screen — light theme, 240x320, dpad-first.
    Matches activity_in_call.xml style.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="HardcodedText,SmallSp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#F5F5F7"
    android:padding="16dp">

    <!-- Incoming label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="INCOMING CALL"
        android:textColor="#8E8E93"
        android:textStyle="bold"
        android:textSize="10sp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="12dp" />

    <!-- Caller name -->
    <TextView
        android:id="@+id/incoming_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1C1C1E"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginBottom="4dp" />

    <!-- Caller number -->
    <TextView
        android:id="@+id/incoming_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#8E8E93"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <!-- Blocked warning -->
    <TextView
        android:id="@+id/incoming_blocked_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BLOCKED — Not on allowed list"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#FF3B30"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Answer / Reject -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/incoming_answer"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginRight="6dp"
            android:text="ANSWER"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#34C759"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:stateListAnimator="@null"
            android:nextFocusRight="@+id/incoming_reject" />

        <Button
            android:id="@+id/incoming_reject"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginLeft="6dp"
            android:text="REJECT"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF3B30"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:stateListAnimator="@null"
            android:nextFocusLeft="@+id/incoming_answer" />

    </LinearLayout>

    <!-- Key hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Green key = Answer     Red key = Reject"
        android:textColor="#C7C7CC"
        android:textSize="10sp"
        android:gravity="center" />

</LinearLayout>