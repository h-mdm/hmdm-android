<?xml version="1.0" encoding="utf-8"?>
<!--
    Incoming call screen layout for Kyocera E4610 (240x320 px, dpad-first).

    Design principles:
    - Large text for gloved/outdoor use
    - Maximum 3 interactive elements to keep dpad navigation trivial
    - High contrast on black background (bright sunlight readability)
    - Answer left, Reject right — matches physical green/red key positions
      on Kyocera E4610 keypad
    - No touch-only gestures (no swipe to answer)

    Focus order:
    1. incoming_answer (default focus on launch)
    2. incoming_reject (dpad right from answer)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="HardcodedText,SmallSp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#000000"
    android:padding="12dp">

    <!-- ===================================================== -->
    <!-- CALLER INFO SECTION                                    -->
    <!-- ===================================================== -->

    <!-- "INCOMING CALL" label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="INCOMING CALL"
        android:textColor="#555555"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <!-- Caller name — resolved from local contacts or falls back to number -->
    <TextView
        android:id="@+id/incoming_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginBottom="4dp" />

    <!-- Caller number -->
    <TextView
        android:id="@+id/incoming_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <!-- ===================================================== -->
    <!-- DIVIDER                                                -->
    <!-- ===================================================== -->

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E1E1E"
        android:layout_marginBottom="20dp" />

    <!-- ===================================================== -->
    <!-- ANSWER / REJECT BUTTONS                                -->
    <!-- ===================================================== -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- ANSWER — green, dpad focus starts here -->
        <Button
            android:id="@+id/incoming_answer"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginRight="6dp"
            android:text="ANSWER"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1B5E20"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:stateListAnimator="@null"
            android:nextFocusRight="@+id/incoming_reject"
            android:nextFocusLeft="@+id/incoming_reject" />

        <!-- REJECT — red -->
        <Button
            android:id="@+id/incoming_reject"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginLeft="6dp"
            android:text="REJECT"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#B71C1C"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:stateListAnimator="@null"
            android:nextFocusLeft="@+id/incoming_answer"
            android:nextFocusRight="@+id/incoming_answer" />

    </LinearLayout>

    <!-- ===================================================== -->
    <!-- KEY HINT BAR                                           -->
    <!-- ===================================================== -->

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Green key = Answer     Red key = Reject"
        android:textColor="#333333"
        android:textSize="10sp"
        android:gravity="center"
        android:layout_marginTop="12dp" />

</LinearLayout>