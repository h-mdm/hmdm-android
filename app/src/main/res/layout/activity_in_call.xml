<?xml version="1.0" encoding="utf-8"?>
<!--
    In-call screen layout for Kyocera E4610 (240x320, dpad-first).

    Layout stack (top to bottom):
      Status label    — "Connected" / "Calling..."
      Timer           — live elapsed time (00:00)
      Caller name     — large, prominent
      Caller number   — secondary
      Divider
      [MUTE]  [SPEAKER]  — secondary controls, side by side
      [      HANG UP    ] — full width, red, primary action

    Dpad focus order:
      MUTE → SPEAKER (right)
      SPEAKER → MUTE (left)
      HANG UP (separate row, always reachable via dpad down)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="HardcodedText,SmallSp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#000000"
    android:padding="12dp">

    <!-- ====================================================== -->
    <!-- CALL STATUS                                             -->
    <!-- ====================================================== -->

    <TextView
        android:id="@+id/incall_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Connected"
        android:textColor="#4CAF50"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <!-- ====================================================== -->
    <!-- CALL TIMER                                              -->
    <!-- ====================================================== -->

    <TextView
        android:id="@+id/incall_timer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- ====================================================== -->
    <!-- CALLER INFO                                             -->
    <!-- ====================================================== -->

    <TextView
        android:id="@+id/incall_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/incall_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- ====================================================== -->
    <!-- DIVIDER                                                 -->
    <!-- ====================================================== -->

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E1E1E"
        android:layout_marginBottom="16dp" />

    <!-- ====================================================== -->
    <!-- MUTE + SPEAKER                                          -->
    <!-- ====================================================== -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="10dp">

        <Button
            android:id="@+id/incall_mute"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginRight="4dp"
            android:text="MUTE"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:stateListAnimator="@null"
            android:nextFocusRight="@+id/incall_speaker"
            android:nextFocusDown="@+id/incall_hangup" />

        <Button
            android:id="@+id/incall_speaker"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginLeft="4dp"
            android:text="SPEAKER"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:stateListAnimator="@null"
            android:nextFocusLeft="@+id/incall_mute"
            android:nextFocusDown="@+id/incall_hangup" />

    </LinearLayout>

    <!-- ====================================================== -->
    <!-- HANG UP — full width, prominent red                     -->
    <!-- ====================================================== -->

    <Button
        android:id="@+id/incall_hangup"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="HANG UP"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#B71C1C"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:stateListAnimator="@null"
        android:nextFocusUp="@+id/incall_mute" />

    <!-- ====================================================== -->
    <!-- KEY HINT                                                -->
    <!-- ====================================================== -->

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Red key = Hang Up"
        android:textColor="#333333"
        android:textSize="10sp"
        android:gravity="center"
        android:layout_marginTop="10dp" />

</LinearLayout>