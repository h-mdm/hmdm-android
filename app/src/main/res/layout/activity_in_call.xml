<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#F5F5F7"
    android:padding="16dp"
    tools:ignore="HardcodedText">

    <TextView
        android:id="@+id/incall_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calling..."
        android:textColor="#007AFF"
        android:textStyle="bold"
        android:textSize="12sp"
        android:layout_marginTop="10dp" />

    <TextView
        android:id="@+id/incall_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#1C1C1E"
        android:textSize="32sp"
        android:layout_marginTop="8dp"
        android:visibility="invisible" />

    <TextView
        android:id="@+id/incall_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textColor="#1C1C1E"
        android:textStyle="bold"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/incall_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#8E8E93"
        android:gravity="center" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/incall_mute"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginRight="4dp"
            android:text="MUTE"
            android:textColor="@color/history_text_selector"
            android:background="@drawable/modern_button_selector"
            android:focusable="true"
            android:nextFocusRight="@+id/incall_speaker"
            android:nextFocusDown="@+id/incall_hangup" />

        <Button
            android:id="@+id/incall_speaker"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginLeft="4dp"
            android:text="SPEAKER"
            android:textColor="@color/history_text_selector"
            android:background="@drawable/modern_button_selector"
            android:focusable="true"
            android:nextFocusLeft="@+id/incall_mute"
            android:nextFocusDown="@+id/incall_hangup" />
    </LinearLayout>

    <Button
        android:id="@+id/incall_hangup"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="HANG UP"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF3B30"
        android:focusable="true"
        android:nextFocusUp="@+id/incall_mute" />
</LinearLayout>