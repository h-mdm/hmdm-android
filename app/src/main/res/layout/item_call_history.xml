<?xml version="1.0" encoding="utf-8"?>
<!--
    Call history row — light theme, 240px wide, dpad-first.
    Type label color: green=incoming, blue=outgoing, red=missed.
    Focus flips all text to white on the blue highlight.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:background="@drawable/contact_item_selector">

    <!-- Call type label -->
    <TextView
        android:id="@+id/history_type"
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textStyle="bold"
        android:gravity="center" />

    <!-- Name + number -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginLeft="4dp">

        <TextView
            android:id="@+id/history_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1C1C1E"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/history_number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#8E8E93"
            android:singleLine="true" />

    </LinearLayout>

    <!-- Date + duration -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/history_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#8E8E93"
            android:gravity="end" />

        <TextView
            android:id="@+id/history_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#C7C7CC"
            android:gravity="end" />

    </LinearLayout>

</LinearLayout>