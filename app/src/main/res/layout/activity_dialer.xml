<?xml version="1.0" encoding="utf-8"?>
<!--
    Modern Light Theme Dialer for Kyocera E4610 (240x320)
    Optimized for D-Pad navigation with high-contrast focus states.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F7"
    tools:ignore="HardcodedText,SmallSp">

    <!-- Top Section: Input Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DIAL OR SEARCH"
            android:textColor="#8E8E93"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:textSize="10sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/search_field_background">

            <EditText
                android:id="@+id/dialer_search"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Name or number..."
                android:textColorHint="#BCBCC0"
                android:textColor="#1C1C1E"
                android:textSize="18sp"
                android:background="@android:color/transparent"
                android:inputType="phone"
                android:imeOptions="actionDone"
                android:singleLine="true"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:paddingLeft="8dp"
                android:nextFocusDown="@+id/dialer_contact_list"
                android:nextFocusRight="@+id/dialer_dial_button" />

            <Button
                android:id="@+id/dialer_dial_button"
                android:layout_width="60dp"
                android:layout_height="36dp"
                android:text="CALL"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#34C759"
                android:focusable="true"
                android:visibility="gone"
                android:nextFocusLeft="@+id/dialer_search"
                android:nextFocusRight="@+id/dialer_backspace" />

            <Button
                android:id="@+id/dialer_backspace"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="⌫"
                android:textSize="18sp"
                android:textColor="#8E8E93"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:focusable="true"
                android:nextFocusLeft="@+id/dialer_dial_button" />
        </LinearLayout>

        <TextView
            android:id="@+id/dialer_formatted_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#007AFF"
            android:textSize="12sp"
            android:paddingTop="4dp"
            android:visibility="gone" />
    </LinearLayout>
    <!-- Add ABOVE the contacts RecyclerView, below the keypad -->
    <Button
        android:id="@+id/dialer_history_link"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="📋  Recent Calls"
        android:textSize="13sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1565C0"
        android:focusable="true" />
    <!-- Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:gravity="center_vertical"
        android:background="#F5F5F7">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CONTACTS"
            android:textColor="#8E8E93"
            android:textStyle="bold"
            android:textSize="11sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STATUS"
            android:textColor="#8E8E93"
            android:textStyle="bold"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Main List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/dialer_contact_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:descendantFocusability="afterDescendants"
        android:nextFocusUp="@+id/dialer_search"
        android:scrollbars="vertical" />

    <!-- Modern Bottom Navigation bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="4dp"
        android:elevation="8dp"
        android:orientation="vertical">


    </LinearLayout>

</LinearLayout>