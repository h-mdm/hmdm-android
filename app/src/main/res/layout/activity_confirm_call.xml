<?xml version="1.0" encoding="utf-8"?>
<!--
    Confirm call screen — light theme.
    Shows caller name/number before placing the outgoing call.
    Whitelist status shown. CALL button hidden if blocked.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="HardcodedText,SmallSp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#F5F5F7"
    android:padding="16dp">

    <!-- Header label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PLACE CALL"
        android:textColor="#8E8E93"
        android:textStyle="bold"
        android:textSize="10sp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp" />

    <!-- Contact name -->
    <TextView
        android:id="@+id/confirm_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1C1C1E"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <!-- Phone number -->
    <TextView
        android:id="@+id/confirm_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#8E8E93"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Blocked warning — shown instead of call button -->
    <TextView
        android:id="@+id/confirm_blocked_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This number is not on the allowed list"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#FF3B30"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="12dp" />

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/confirm_call_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginRight="6dp"
            android:text="CALL"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#34C759"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:stateListAnimator="@null"
            android:nextFocusRight="@+id/confirm_cancel_button" />

        <Button
            android:id="@+id/confirm_cancel_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginLeft="6dp"
            android:text="CANCEL"
            android:textStyle="bold"
            android:textColor="#FF3B30"
            android:background="@drawable/modern_button_selector"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:stateListAnimator="@null"
            android:nextFocusLeft="@+id/confirm_call_button" />

    </LinearLayout>

    <!-- Key hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Green key = Call     Back = Cancel"
        android:textColor="#C7C7CC"
        android:textSize="10sp"
        android:gravity="center" />

</LinearLayout>